# ===========================================
# Environment Configuration Template
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ===========================================

# ==================
# Database Settings
# ==================
POSTGRES_DB=trayectorias
POSTGRES_USER=trayectorias_user
POSTGRES_PASSWORD=changeme_secure_password
DATABASE_URL=postgresql://trayectorias_user:changeme_secure_password@postgres:5432/trayectorias

# Alternative format for connection details
DATABASE_HOST=postgres
DATABASE_PORT=5432

# ==================
# Django Settings
# ==================
SECRET_KEY=django-insecure-change-this-to-a-long-random-string-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,trayectoriasafro.org,db.trayectoriasafro.org

# Django Admin
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@trayectoriasafro.org
DJANGO_SUPERUSER_PASSWORD=changeme

# Logging (set to True for file-based logging, False for console only)
LOG_LEVEL=INFO
USE_FILE_LOGGING=False

# ==================
# Email Settings (SendGrid)
# ==================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key-here
DEFAULT_FROM_EMAIL=noreply@trayectoriasafro.org

# For development, you can use console backend:
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# ==================
# Security Settings
# ==================
# Set to True only in development
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# CORS Settings (if needed for separate frontend domain)
CORS_ALLOWED_ORIGINS=https://trayectoriasafro.org,http://localhost:3000
CSRF_TRUSTED_ORIGINS=https://trayectoriasafro.org,https://db.trayectoriasafro.org

# ==================
# Application Settings
# ==================
# Language
LANGUAGE_CODE=es-mx
TIME_ZONE=America/Mexico_City

# Pagination
REST_FRAMEWORK_PAGE_SIZE=20

# ==================
# Logging
# ==================
LOG_LEVEL=INFO

# ==================
# Svelte Frontend
# ==================
# Only needed for development
VITE_API_BASE_URL=http://localhost:8000

# ==================
# Optional: Database Backup
# ==================
BACKUP_DIR=/backups
BACKUP_KEEP_DAYS=30
